@model IEnumerable<Registros_ColegioSJ.Models.Estudiante>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-people me-2"></i>Gestión de Estudiantes</h2>
        <a asp-action="Crear" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-person-plus-fill me-2"></i>Nuevo Estudiante
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nombre Completo</th>
                        <th>Grado</th>
                        <th>Fecha Nac.</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Nombre @item.Apellido</td>
                            <td><span class="badge bg-info text-dark">@item.Grado</span></td>
                            <td>@item.FechaNacimiento</td>
                            <td class="text-center">
                                <a asp-action="Editar" asp-route-id="@item.EstudianteId" class="btn btn-sm btn-outline-warning mx-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Eliminar" asp-route-id="@item.EstudianteId"
                                       class="btn btn-sm btn-outline-danger mx-1"
                                       onclick="return confirm('¿Estás seguro de eliminar este registro?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>