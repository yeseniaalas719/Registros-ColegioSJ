@model Registros_ColegioSJ.Models.Estudiante

@{
    ViewData["Title"] = "Editar Estudiante";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 p-4 rounded-4">
                <h3 class="mb-4 text-center">
                    <i class="bi bi-pencil-square text-primary me-2"></i>Editar Estudiante
                </h3>

                <form asp-action="Editar" method="post">
                    <input type="hidden" asp-for="EstudianteId" />

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold">Nombres</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej. Juan Carlos" required />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Apellido" class="form-label fw-bold">Apellidos</label>
                        <input asp-for="Apellido" class="form-control" placeholder="Ej. Pérez" required />
                        <span asp-validation-for="Apellido" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Grado" class="form-label fw-bold">Grado</label>
                            <input asp-for="Grado" class="form-control" placeholder="Ej. 9no Grado" required />
                            <span asp-validation-for="Grado" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaNacimiento" class="form-label fw-bold">Fecha de Nacimiento</label>
                            <input asp-for="FechaNacimiento" type="date" class="form-control" required />
                            <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-left me-1"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                            <i class="bi bi-save me-1"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}