@{
    ViewData["Title"] = "Página de Inicio";
}

<style>
    .card-tile {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border: none;
        border-radius: 15px;
    }

        .card-tile:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            cursor: pointer;
        }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }
</style>

<div class="container mt-0">

    @* Sección de Bienvenida *@
    <div class="row mt-0 mb-4">
        <div class="col-12">
            <div class="p-3 rounded-4 bg-white shadow-sm border-start border-white border-5 d-flex flex-column flex-md-row align-items-center justify-content-center text-center">
            
                <div class="opacity-25 text-primary me-md-4 mb-2 mb-md-0">
                    <i class="bi bi-mortarboard-fill" style="font-size: 3rem;"></i>
                </div>
            
                <div>
                    <h1 class="h4 fw-bold text-dark mb-1">Bienvenida/o</h1>
                    <p class="text-muted mb-0 small">Panel de control de Registros Colegio San José.</p>
                </div>

            </div>
        </div>
    </div>
    <div class="row g-4 justify-content-center">

        
        @* Gestión de Alumnos *@
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm card-tile text-center p-3">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h5 class="card-title fw-bold">Estudiantes</h5>
                    <p class="card-text text-muted small">Registrar nuevos alumnos, ver el listado completo y gestionar expedientes personales.</p>
                    <a asp-controller="Estudiantes" asp-action="Index" class="btn btn-outline-primary w-100 rounded-pill mt-auto">
                        <i class="bi bi-arrow-right-circle me-2"></i> Ir a Registros
                    </a>
                </div>
            </div>
        </div>

        @* Ingreso de Notas *@
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm card-tile text-center p-3">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="icon-box bg-success bg-opacity-10 text-success">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h5 class="card-title fw-bold">Asignaturas & Calificaciones</h5>
                    <p class="card-text text-muted small">Cargar notas finales de evaluaciones de los alumnos y gestiona materias.</p>
                    <a asp-controller="Calificaciones" asp-action="Registrar" class="btn btn-outline-success w-100 rounded-pill">
                        <i class="bi bi-journal-check me-2"></i> Ingreso de calificaciones
                    </a>
                </div>
            </div>
        </div>

        @* Mantenimiento de Materias *@
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm card-tile text-center p-3">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-book"></i>
                    </div>
                    <h5 class="card-title fw-bold">Asignaturas</h5>
                    <p class="card-text text-muted small">Mantenimiento de materias disponibles y docentes asignados.</p>
                    <a asp-controller="Asignaturas" asp-action="Index" class="btn btn-outline-warning w-100 rounded-pill mt-auto">
                        <i class="bi bi-journal-text me-2"></i> Gestionar Materias
                    </a>
                </div>
            </div>
        </div>

        @* Reportes y Gráficas *@
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm card-tile text-center p-3">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="icon-box bg-info bg-opacity-10 text-info">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h5 class="card-title fw-bold">Análisis de Rendimiento</h5>
                    <p class="card-text text-muted small">Visualizar la gráfica de promedios generales y el ranking de estudiantes actuales.</p>
                    <a asp-controller="Reportes" asp-action="PromediosEstudiantes" class="btn btn-outline-info w-100 rounded-pill mt-auto">
                        <i class="bi bi-bar-chart-line-fill me-2"></i> Ver Gráficas
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


    @* 3. SECCIÓN DE SCRIPT*@
    @section Scripts {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <script>
        </script>

}
    