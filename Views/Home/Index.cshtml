@{
    ViewData["Title"] = "Página de Inicio";
}

<style>
    .card-tile {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border: none;
        border-radius: 15px;
    }

        .card-tile:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            cursor: pointer;
        }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }
</style>

<div class="container mt-5">
    @* Sección de Bienvenida *@
    <div class="row mb-5">
        <div class="col-12 text-center text-md-start">
            <h1 class="display-5 fw-bold text-primary">Bienvenida al Sistema Escolar</h1>
            <p class="lead text-muted">Panel de control de Registros ColegioSJ.</p>
            <div class="mx-auto mx-md-0 bg-primary" style="height: 3px; width: 60px;"></div>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        
        @* Gestión de Alumnos *@
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm card-tile text-center p-3">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h5 class="card-title fw-bold">Estudiantes</h5>
                    <p class="card-text text-muted small">Registrar nuevos alumnos, ver el listado completo y gestionar expedientes personales.</p>
                    <a asp-controller="Estudiantes" asp-action="Index" class="btn btn-primary rounded-pill mt-auto shadow-sm">
                        <i class="bi bi-arrow-right-circle me-1"></i> Ir a Registros
                    </a>
                </div>
            </div>
        </div>

        @* Ingreso de Notas *@
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm card-tile text-center p-3">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="icon-box bg-success bg-opacity-10 text-success">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h5 class="card-title fw-bold">Calificaciones</h5>
                    <p class="card-text text-muted small">Cargar notas finales por asignatura y actualizar evaluaciones de los alumnos.</p>
                    <a asp-controller="Calificaciones" asp-action="Index" class="btn btn-outline-success w-100 rounded-pill">
                        <i class="bi bi-journal-check me-2"></i> Ingresar Notas
                    </a>
                </div>
            </div>
        </div>

        @*Reportes y Gráficas*@
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm card-tile text-center p-3 border-primary border-opacity-25"
                 onclick="location.href='@Url.Action("PromediosEstudiantes", "Reportes")'">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="icon-box bg-info bg-opacity-10 text-info">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h5 class="card-title fw-bold text-primary">Análisis de Rendimiento</h5>
                    <p class="card-text text-muted small">Visualizar la gráfica de promedios generales y el ranking de estudiantes actuales.</p>
                    <a asp-controller="Reportes" asp-action="PromediosEstudiantes" class="btn btn-primary w-100 rounded-pill shadow-sm">
                        <i class="bi bi-bar-chart-line-fill me-2"></i> Ver Gráficas
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


    @* 3. SECCIÓN DE SCRIPT*@
    @section Scripts {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <script>
        </script>

}
    