@model IEnumerable<Registros_ColegioSJ.Models.Asignatura>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-book me-2"></i>Catálogo de Asignaturas</h2>
        <a asp-action="Crear" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Nueva Materia
        </a>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="bi bi-journal-x display-4"></i>
                <p class="mt-3">Aún no has registrado ninguna materia.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model) {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm border-start border-primary border-4">
                        <div class="card-body">
                            <h5 class="fw-bold text-primary">@item.NombreAsignatura</h5>
                            <p class="text-muted mb-3"><i class="bi bi-person-badge me-2"></i>Docente: @item.Docente</p>
                            <div class="d-flex justify-content-end border-top pt-3">
                                <a asp-action="Eliminar" asp-route-id="@item.AsignaturaId" 
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('¿Seguro que deseas eliminar esta materia?')">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>