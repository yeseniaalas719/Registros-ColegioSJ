@model Registros_ColegioSJ.Models.Asignatura

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Registrar Materia</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Crear">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre de la Asignatura</label>
                            <input asp-for="NombreAsignatura" class="form-control" placeholder="Ingrese Nombre" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Docente</label>
                            <input asp-for="Docente" class="form-control" placeholder="Ingrese nombre docente" required />
                        </div>
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary rounded-pill">Guardar Materia</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>