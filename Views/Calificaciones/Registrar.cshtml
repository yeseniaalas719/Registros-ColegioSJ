@model Registros_ColegioSJ.Models.Expediente

<div class="container mt-2">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-dark mb-0">
            <i class="bi bi-pencil-square me-2"></i>Ingreso de Calificaciones
        </h2>
        
        <a asp-action="Index" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver al Listado
        </a>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0 text-center"><i class="bi bi-pencil-fill me-2"></i>Ingreso de Calificaciones</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Registrar">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Seleccionar Estudiante</label>
                            <select asp-for="EstudianteId" class="form-select" asp-items="ViewBag.Estudiantes">
                                <option value="">-- Seleccione un alumno --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-end mb-1">
                                <label class="form-label fw-bold mb-0">Materia / Asignatura</label>
                                <a asp-controller="Asignaturas" asp-action="Crear" class="text-decoration-none small text-primary" target="_blank">
                                    <i class="bi bi-plus-circle"></i> Nueva materia
                                </a>
                            </div>
                            <select asp-for="AsignaturaId" class="form-select" asp-items="ViewBag.Asignaturas">
                                <option value="">-- Seleccione materia --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nota Final (0.0 - 10.0)</label>
                            <input asp-for="NotaFinal" class="form-control form-control-lg text-center" placeholder="0.0" step="0.1" type="number" min="0" max="10" required />
                            <span asp-validation-for="NotaFinal" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Observaciones</label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2" placeholder="Ej. Excelente desempeño"></textarea>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill">Guardar Calificación</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill">Ver Listado</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>